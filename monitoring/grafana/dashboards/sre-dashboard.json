  "links": [],
  "liveNow": false,
  "templating": {
    "list": [
      {
        "name": "application",
        "label": "서비스",
        "type": "query",
        "datasource": {
          "type": "prometheus",
          "uid": "prometheus"
        },
        "query": {
          "query": "label_values(jvm_memory_used_bytes, application)",
          "refId": "A"
        },
        "includeAll": true,
        "allValue": ".*",
        "multi": false,
        "current": {
          "text": "All",
          "value": "$__all"
        },
        "refresh": 2,
        "sort": 1,
        "hide": 0
      }
    ]
  },
  "panels": [
    {
      "collapsed": false,
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 0
      },
      "id": 100,
      "panels": [],
      "title": "🔴 [Tier 1] Business Impact & SLO (서비스 생존 및 목표 달성률)",
      "type": "row"
    },
    {
      "title": "1. [SLI] 결제 Saga 완료율 (SLI)",
      "type": "gauge",
      "gridPos": {
        "h": 7,
        "w": 5,
        "x": 0,
        "y": 1
      },
      "targets": [
        {
          "expr": "clamp_max((sum(rate(business_payment_success_total{application=~\"$application\"}[1m])) / sum(rate(business_payment_attempts_total{application=~\"$application\"}[1m])) * 100) or vector(100), 100)"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "thresholds": {
            "steps": [
              {
                "color": "red",
                "value": null
              },
              {
                "color": "orange",
                "value": 99.5
              },
              {
                "color": "green",
                "value": 99.9
              }
            ]
          }
        }
      }
    },
    {
      "title": "2. [Alert] 에러 예산 소진 속도 (Burn Rate)",
      "type": "gauge",
      "gridPos": {
        "h": 7,
        "w": 5,
        "x": 5,
        "y": 1
      },
      "targets": [
        {
          "expr": "saga:payment_error_rate:ratio_rate5m / 0.001 or vector(0)"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "none",
          "min": 0,
          "max": 20,
          "thresholds": {
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "orange",
                "value": 1
              },
              {
                "color": "red",
                "value": 14.4
              }
            ]
          }
        }
      }
    },
    {
      "title": "3. [SLO] 남은 에러 예산 (Error Budget)",
      "type": "stat",
      "gridPos": {
        "h": 7,
        "w": 5,
        "x": 10,
        "y": 1
      },
      "targets": [
        {
          "expr": "(100 - (saga:payment_error_rate:ratio_rate30d / 0.001 * 100)) or vector(100)"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "thresholds": {
            "steps": [
              {
                "color": "red",
                "value": null
              },
              {
                "color": "orange",
                "value": 20
              },
              {
                "color": "green",
                "value": 80
              }
            ]
          }
        }
      }
    },
    {
      "title": "4. [P0] 자동 복구 실패 (상세 분석용)",
      "type": "timeseries",
      "gridPos": {
        "h": 7,
        "w": 4,
        "x": 15,
        "y": 1
      },
      "targets": [
        {
          "expr": "sum(rate(business_payment_pg_refund_fatal_total{application=~\"$application\"}[1m]))",
          "legendFormat": "Fatal Recovery Failure",
          "exemplar": true
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "fixed",
            "fixedColor": "red"
          },
          "custom": {
            "drawStyle": "bars",
            "pointSize": 10
          },
          "unit": "short"
        }
      }
    },
    {
      "title": "5. [Business] 자동 환불 방어율 (Fallback Success Rate)",
      "type": "timeseries",
      "gridPos": {
        "h": 7,
        "w": 5,
        "x": 19,
        "y": 1
      },
      "targets": [
        {
          "expr": "(sum(rate(business_payment_pg_refund_request_total{application=~\"$application\"}[1m])) / (sum(rate(business_payment_pg_refund_request_total{application=~\"$application\"}[1m])) + sum(rate(business_payment_pg_refund_fatal_total{application=~\"$application\"}[1m]))) * 100) or vector(100)",
          "legendFormat": "Fallback Success Rate",
          "exemplar": true
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "red",
                "value": null
              },
              {
                "color": "orange",
                "value": 80
              },
              {
                "color": "green",
                "value": 95
              }
            ]
          }
        }
      }
    },
    {
      "collapsed": false,
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 8
      },
      "id": 200,
      "panels": [],
      "title": "🟡 [Tier 2] Application Performance (애플리케이션 RED 지표)",
      "type": "row"
    },
    {
      "title": "6. [Latency] API 응답 지연 시간 (p95)",
      "type": "timeseries",
      "gridPos": {
        "h": 7,
        "w": 8,
        "x": 0,
        "y": 9
      },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum(rate(http_server_requests_seconds_bucket{application=~\"$application\"}[5m])) by (le))",
          "legendFormat": "p95 Latency",
          "exemplar": true
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "min": 0,
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "fillOpacity": 10
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "red",
                "value": 0.5
              }
            ]
          }
        },
        "overrides": [
          {
            "matcher": {
              "id": "byName",
              "options": "p95 Latency"
            },
            "properties": [
              {
                "id": "custom.lineStyle",
                "value": {
                  "fill": "solid"
                }
              }
            ]
          }
        ]
      }
    },
    {
      "title": "7. [Errors] 서버 내부 에러율 (5xx Rate)",
      "type": "timeseries",
      "gridPos": {
        "h": 7,
        "w": 8,
        "x": 8,
        "y": 9
      },
      "targets": [
        {
          "expr": "((sum(rate(http_server_requests_seconds_count{status=~\"5..\",application=~\"$application\"}[1m])) / sum(rate(http_server_requests_seconds_count{application=~\"$application\"}[1m]))) * 100) or vector(0)",
          "legendFormat": "5xx Error Rate",
          "exemplar": true
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "fillOpacity": 15
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "orange",
                "value": 1
              },
              {
                "color": "red",
                "value": 5
              }
            ]
          }
        }
      }
    },
    {
      "title": "8. [Traffic] 결제 처리량 (RPS)",
      "type": "timeseries",
      "gridPos": {
        "h": 7,
        "w": 8,
        "x": 16,
        "y": 9
      },
      "targets": [
        {
          "expr": "sum(rate(http_server_requests_seconds_count{application=~\"$application\"}[1m]))",
          "legendFormat": "RPS"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": {
            "fillOpacity": 10,
            "drawStyle": "line",
            "lineInterpolation": "smooth"
          }
        }
      }
    },
