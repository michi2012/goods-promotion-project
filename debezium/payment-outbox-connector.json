{
  "name": "payment-outbox-connector",
  "config": {
    "connector.class": "io.debezium.connector.mysql.MySqlConnector",
    "tasks.max": "1",
    "database.hostname": "mysql-c",
    "database.port": "3306",
    "database.user": "root",
    "database.password": "root",
    "database.server.id": "184055",
    "topic.prefix": "payment",
    "database.include.list": "payment",
    "table.include.list": "payment.outbox_event",
    "schema.history.internal.kafka.bootstrap.servers": "kafka:9092",
    "schema.history.internal.kafka.topic": "schema-changes.payment",
    "database.connectionTimeZone": "Asia/Seoul",
    "snapshot.mode": "schema_only",
    "transforms": "outbox",
    "transforms.outbox.type": "io.debezium.transforms.outbox.EventRouter",
    "transforms.outbox.table.field.event.key": "aggregate_id",
    "transforms.outbox.table.field.event.payload": "payload",
    "transforms.outbox.route.by.field": "topic",
    "transforms.outbox.route.topic.replacement": "${routedByValue}",
    "transforms.outbox.table.op.invalid.behavior": "warn",
    "transforms.outbox.table.fields.additional.placement": "traceparent:header",
    "value.converter": "org.apache.kafka.connect.storage.StringConverter",
    "key.converter": "org.apache.kafka.connect.storage.StringConverter"
  }
}
