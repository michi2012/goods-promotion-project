{
  "enabledMcpServers": ["mysql", "codex"],
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "powershell -NonInteractive -File .claude/hooks/pre-tool-check.ps1"
          }
        ]
      },
      {
        "matcher": "PowerShell",
        "hooks": [
          {
            "type": "command",
            "command": "powershell -NonInteractive -File .claude/hooks/pre-tool-check.ps1"
          }
        ]
      }
    ]
  }
}
